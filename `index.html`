<!DOCTYPE html>
<html lang="hi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ultimate Billing Pro - Sellable</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.23/jspdf.plugin.autotable.min.js"></script>
    <style>
        @media print {
            .no-print { display: none !important; }
            .print-only { display: block !important; }
            body { background: white; padding: 0; }
            .bill-container { box-shadow: none; border: none; width: 100%; }
        }
    </style>
</head>
<body class="bg-slate-100 min-h-screen p-4 md:p-6 font-sans">

    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-3 gap-6">
        
        <!-- Left Panel: Settings (No Print) -->
        <div class="lg:col-span-1 space-y-4 no-print">
            <div class="bg-white p-5 rounded-xl shadow-md border-t-4 border-blue-600">
                <h2 class="text-lg font-bold text-gray-700 mb-3 flex items-center">
                    ⚙️ Shop Settings
                </h2>
                <div class="space-y-3">
                    <input id="shopName" type="text" placeholder="Shop Name" class="w-full border p-2 rounded text-sm focus:border-blue-500 outline-none" oninput="saveSettings()">
                    <input id="shopAddress" type="text" placeholder="Shop Address" class="w-full border p-2 rounded text-sm focus:border-blue-500 outline-none" oninput="saveSettings()">
                    <input id="shopGST" type="text" placeholder="GSTIN (Optional)" class="w-full border p-2 rounded text-sm focus:border-blue-500 outline-none" oninput="saveSettings()">
                </div>
            </div>

            <div class="bg-white p-5 rounded-xl shadow-md border-t-4 border-green-500">
                <h2 class="text-lg font-bold text-gray-700 mb-3">👤 Customer Details</h2>
                <div class="space-y-3">
                    <input id="custName" type="text" placeholder="Customer Name" class="w-full border p-2 rounded text-sm outline-none">
                    <input id="custPhone" type="number" placeholder="WhatsApp Number (91...)" class="w-full border p-2 rounded text-sm outline-none">
                </div>
            </div>
        </div>

        <!-- Right Panel: Billing Area -->
        <div class="lg:col-span-2 bg-white p-6 rounded-xl shadow-md bill-container border border-gray-200">
            
            <div class="no-print">
                <h2 class="text-xl font-bold text-gray-800 mb-4">🛒 Add Items</h2>
                <div class="grid grid-cols-1 md:grid-cols-4 gap-2 mb-6">
                    <input id="itemDesc" type="text" placeholder="Item Name" class="border p-2 rounded md:col-span-1 text-sm">
                    <input id="itemPrice" type="number" placeholder="Price" class="border p-2 rounded text-sm">
                    <input id="itemQty" type="number" placeholder="Qty" class="border p-2 rounded text-sm">
                    <button onclick="addItem()" class="bg-blue-600 text-white px-4 py-2 rounded font-bold hover:bg-blue-700 text-sm tracking-wide">+ ADD</button>
                </div>
            </div>

            <!-- Invoice Header (Visible in Print) -->
            <div class="text-center mb-6 border-b pb-4">
                <h1 id="dispShopName" class="text-3xl font-black text-blue-800 uppercase">SHOP NAME</h1>
                <p id="dispAddress" class="text-gray-600 text-sm">Shop Address, City</p>
                <p id="dispGST" class="text-gray-500 text-xs font-bold mt-1 uppercase"></p>
            </div>

            <div class="flex justify-between mb-4 text-sm">
                <div>
                    <p><strong>To:</strong> <span id="dispCustName">Customer</span></p>
                    <p><strong>Phone:</strong> <span id="dispCustPhone">-</span></p>
                </div>
                <div class="text-right">
                    <p><strong>Date:</strong> <span id="billDate"></span></p>
                    <p><strong>Inv No:</strong> #<span id="invNo"></span></p>
                </div>
            </div>

            <table class="w-full text-left border-collapse mb-6">
                <thead>
                    <tr class="bg-slate-800 text-white">
                        <th class="p-2 border border-slate-700">Item Description</th>
                        <th class="p-2 border border-slate-700 text-center">Price</th>
                        <th class="p-2 border border-slate-700 text-center">Qty</th>
                        <th class="p-2 border border-slate-700 text-right">Total</th>
                        <th class="p-2 border border-slate-700 text-center no-print">❌</th>
                    </tr>
                </thead>
                <tbody id="billBody">
                    <!-- Items go here -->
                </tbody>
            </table>

            <div class="flex flex-col items-end space-y-2">
                <div class="text-xl font-black text-slate-800 border-t-2 border-slate-800 pt-2 w-full text-right">
                    GRAND TOTAL: ₹<span id="grandTotal">0.00</span>
                </div>
            </div>

            <!-- Action Buttons (No Print) -->
            <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-3 no-print">
                <button onclick="generatePDF()" class="bg-red-600 text-white py-3 rounded-lg font-bold shadow hover:bg-red-700 transition flex items-center justify-center gap-2">
                    📄 Download PDF
                </button>
                <button onclick="window.print()" class="bg-slate-700 text-white py-3 rounded-lg font-bold shadow hover:bg-slate-900 transition flex items-center justify-center gap-2">
                    🖨️ Print Bill
                </button>
                <button onclick="sendWhatsApp()" class="bg-green-600 text-white py-3 rounded-lg font-bold shadow hover:bg-green-700 transition flex items-center justify-center gap-2">
                    💬 WhatsApp Bill
                </button>
            </div>
        </div>
    </div>

    <script>
        let items = [];
        document.getElementById('billDate').innerText = new Date().toLocaleDateString();
        document.getElementById('invNo').innerText = Math.floor(Math.random() * 9000) + 1000;

        window.onload = function() {
            document.getElementById('shopName').value = localStorage.getItem('shopName') || '';
            document.getElementById('shopAddress').value = localStorage.getItem('shopAddress') || '';
            document.getElementById('shopGST').value = localStorage.getItem('shopGST') || '';
            updateDisp();
        };

        function saveSettings() {
            localStorage.setItem('shopName', document.getElementById('shopName').value);
            localStorage.setItem('shopAddress', document.getElementById('shopAddress').value);
            localStorage.setItem('shopGST', document.getElementById('shopGST').value);
            updateDisp();
        }

        function updateDisp() {
            document.getElementById('dispShopName').innerText = document.getElementById('shopName').value || "Your Shop Name";
            document.getElementById('dispAddress').innerText = document.getElementById('shopAddress').value || "Address Details";
            document.getElementById('dispGST').innerText = document.getElementById('shopGST').value ? "GSTIN: " + document.getElementById('shopGST').value : "";
        }

        function addItem() {
            const desc = document.getElementById('itemDesc').value;
            const price = parseFloat(document.getElementById('itemPrice').value);
            const qty = parseFloat(document.getElementById('itemQty').value);
            const cName = document.getElementById('custName').value;
            const cPhone = document.getElementById('custPhone').value;

            if(desc && price && qty) {
                items.push({ desc, price, qty, total: (price * qty).toFixed(2) });
                document.getElementById('dispCustName').innerText = cName || "Customer";
                document.getElementById('dispCustPhone').innerText = cPhone || "-";
                renderTable();
                document.getElementById('itemDesc').value = '';
                document.getElementById('itemPrice').value = '';
                document.getElementById('itemQty').value = '';
            }
        }

        function removeItem(index) {
            items.splice(index, 1);
            renderTable();
        }

        function renderTable() {
            let html = '';
            let total = 0;
            items.forEach((item, index) => {
                html += `<tr class="border-b">
                    <td class="p-2 border">${item.desc}</td>
                    <td class="p-2 border text-center">${item.price}</td>
                    <td class="p-2 border text-center">${item.qty}</td>
                    <td class="p-2 border text-right font-bold">${item.total}</td>
                    <td class="p-2 border text-center no-print">
                        <button onclick="removeItem(${index})" class="text-red-500">✖</button>
                    </td>
                </tr>`;
                total += parseFloat(item.total);
            });
            document.getElementById('billBody').innerHTML = html;
            document.getElementById('grandTotal').innerText = total.toFixed(2);
        }

        function generatePDF() {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF();
            doc.text(document.getElementById('shopName').value || "Invoice", 105, 20, null, null, "center");
            doc.autoTable({
                head: [['Item', 'Price', 'Qty', 'Total']],
                body: items.map(i => [i.desc, i.price, i.qty, i.total]),
                startY: 40
            });
            doc.text("Grand Total: " + document.getElementById('grandTotal').innerText, 14, doc.lastAutoTable.finalY + 10);
            doc.save("Bill.pdf");
        }

        function sendWhatsApp() {
            const phone = document.getElementById('custPhone').value;
            const shop = document.getElementById('shopName').value;
            const total = document.getElementById('grandTotal').innerText;
            if(!phone) return alert("Pehle Customer ka WhatsApp Number daalein!");
            
            const msg = `Hello! *${shop}* se aapka bill amount *₹${total}* hai. Dhanyawad!`;
            const url = `https://wa.me/${phone}?text=${encodeURIComponent(msg)}`;
            window.open(url, '_blank');
        }
    </script>
</body>
</html>
