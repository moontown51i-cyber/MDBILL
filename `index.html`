<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Free Billing Software</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
</head>
<body class="bg-gray-100 p-5">
    <div class="max-w-4xl mx-auto bg-white p-8 rounded-lg shadow-lg">
        <h1 class="text-2xl font-bold mb-5 text-center text-blue-600">Apna Billing Software</h1>
        
        <!-- Customer Details -->
        <div class="grid grid-cols-2 gap-4 mb-6">
            <input id="custName" type="text" placeholder="Customer Name" class="border p-2 rounded">
            <input id="custPhone" type="text" placeholder="Phone Number" class="border p-2 rounded">
        </div>

        <!-- Item Entry -->
        <div class="flex gap-2 mb-6">
            <input id="itemDesc" type="text" placeholder="Item Description" class="border p-2 flex-grow rounded">
            <input id="itemPrice" type="number" placeholder="Price" class="border p-2 w-24 rounded">
            <input id="itemQty" type="number" placeholder="Qty" class="border p-2 w-20 rounded">
            <button onclick="addItem()" class="bg-blue-500 text-white px-4 py-2 rounded">Add</button>
        </div>

        <!-- Bill Table -->
        <table class="w-full mb-6 border-collapse border">
            <thead>
                <tr class="bg-gray-200">
                    <th class="border p-2 text-left">Item</th>
                    <th class="border p-2">Price</th>
                    <th class="border p-2">Qty</th>
                    <th class="border p-2">Total</th>
                </tr>
            </thead>
            <tbody id="billBody"></tbody>
        </table>

        <div class="text-right font-bold text-xl mb-6">
            Total Amount: ₹<span id="grandTotal">0</span>
        </div>

        <button onclick="generatePDF()" class="w-full bg-green-600 text-white py-3 rounded-lg font-bold">Download PDF Bill</button>
    </div>

    <script>
        let items = [];
        function addItem() {
            const desc = document.getElementById('itemDesc').value;
            const price = document.getElementById('itemPrice').value;
            const qty = document.getElementById('itemQty').value;
            if(desc && price && qty) {
                items.push({ desc, price, qty, total: price * qty });
                renderTable();
                document.getElementById('itemDesc').value = '';
                document.getElementById('itemPrice').value = '';
                document.getElementById('itemQty').value = '';
            }
        }

        function renderTable() {
            let html = '';
            let total = 0;
            items.forEach(item => {
                html += `<tr><td class="border p-2">${item.desc}</td><td class="border p-2 text-center">${item.price}</td><td class="border p-2 text-center">${item.qty}</td><td class="border p-2 text-center">${item.total}</td></tr>`;
                total += item.total;
            });
            document.getElementById('billBody').innerHTML = html;
            document.getElementById('grandTotal').innerText = total;
        }

        function generatePDF() {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF();
            doc.text("INVOICE", 10, 10);
            doc.text("Customer: " + document.getElementById('custName').value, 10, 20);
            let y = 30;
            items.forEach(item => {
                doc.text(`${item.desc} - ${item.qty} x ${item.price} = ${item.total}`, 10, y);
                y += 10;
            });
            doc.text("Grand Total: " + document.getElementById('grandTotal').innerText, 10, y + 10);
            doc.save("bill.pdf");
        }
    </script>
</body>
</html>
